{
    "name": "drupal/recommended-project",
    "description": "Project template for Drupal projects with a relocated document root",
    "type": "project",
    "license": "GPL-2.0-or-later",
    "homepage": "https://www.drupal.org/project/drupal",
    "support": {
        "docs": "https://www.drupal.org/docs/user_guide/en/index.html",
        "chat": "https://www.drupal.org/node/314178"
    },
    "repositories": [
        {
            "type": "composer",
            "url": "https://packages.drupal.org/8"
        }
    ],
    "require": {
        "composer/installers": "^2.3",
        "drupal/bootstrap_italia": "^2.17",
        "drupal/color_field": "^3.0",
        "drupal/components": "^3.2",
        "drupal/core-composer-scaffold": "^11.3",
        "drupal/core-project-message": "^11.3",
        "drupal/core-recipe-unpack": "^11.3",
        "drupal/core-recommended": "^11.3",
        "drupal/entity_clone": "^2.1@beta",
        "drupal/entity_reference_display": "^2.0",
        "drupal/entity_usage": "^2.0@beta",
        "drupal/field_group": "^4.0",
        "drupal/file_rename": "^1.0",
        "drupal/focal_point": "^2.1",
        "drupal/fontawesome": "^3.0",
        "drupal/gutenberg": "^3.0",
        "drupal/imce": "^3.1",
        "drupal/layout_paragraphs": "^2.1",
        "drupal/paragraph_sdc": "^2.0",
        "drupal/paragraphs": "^1.20",
        "drupal/pathauto": "^1.15",
        "drupal/ui_patterns": "^2.0",
        "drupal/ui_patterns_paragraphs": "^1.0@alpha",
        "drupal/ui_patterns_settings": "^2.4",
        "drupal/views_field_view": "^1.0@beta",
        "guzzlehttp/psr7": "2.12.1 as 2.10.4"
    },
    "conflict": {
        "drupal/drupal": "*"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "composer/installers": true,
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "drupal/core-composer-scaffold": true,
            "drupal/core-project-message": true,
            "drupal/core-recipe-unpack": true,
            "php-http/discovery": true,
            "php-tuf/composer-integration": true,
            "phpstan/extension-installer": true,
            "tbachert/spi": true
        },
        "sort-packages": true,
        "policy": {
            "advisories": {
                "ignore-id": {
                    "PKSA-93qv-9n9h-6k6p": "guzzle CVE-2026-55767 (dot-only cookie domains, severidad media). drupal/core-recommended 11.3.12 clava guzzle a ~7.10.0; el fix esta en 7.12.1, que exige promises ^2.5 y choca con el promises ~2.3.0 que clava core (rangos disjuntos, no aliasable). Excepcion temporal: retirar al pasar a 11.4.0 (o a un 11.3.x que reempaquete guzzle). Ver TODO #2.",
                    "PKSA-k22t-f949-t9g6": "guzzle CVE-2026-55568 (downgrade silencioso de proxy HTTPS, severidad media). Misma causa y misma condicion de retirada que la anterior. Ver TODO #2."
                }
            }
        }
    },
    "extra": {
        "drupal-scaffold": {
            "locations": {
                "web-root": "web/"
            }
        },
        "installer-paths": {
            "web/core": [
                "type:drupal-core"
            ],
            "web/libraries/{$name}": [
                "type:drupal-library"
            ],
            "web/modules/contrib/{$name}": [
                "type:drupal-module"
            ],
            "web/profiles/contrib/{$name}": [
                "type:drupal-profile"
            ],
            "web/themes/contrib/{$name}": [
                "type:drupal-theme"
            ],
            "drush/Commands/contrib/{$name}": [
                "type:drupal-drush"
            ],
            "web/modules/custom/{$name}": [
                "type:drupal-custom-module"
            ],
            "web/profiles/custom/{$name}": [
                "type:drupal-custom-profile"
            ],
            "web/themes/custom/{$name}": [
                "type:drupal-custom-theme"
            ],
            "recipes/{$name}": [
                "type:drupal-recipe"
            ]
        },
        "drupal-core-project-message": {
            "include-keys": [
                "homepage",
                "support"
            ],
            "post-create-project-cmd-message": [
                "<bg=blue;fg=white>                                                         </>",
                "<bg=blue;fg=white>  Congratulations, you’ve installed the Drupal codebase  </>",
                "<bg=blue;fg=white>  from the drupal/recommended-project template!          </>",
                "<bg=blue;fg=white>                                                         </>",
                "",
                "<bg=yellow;fg=black>Next steps</>:",
                "  * Install the site: https://www.drupal.org/docs/installing-drupal",
                "  * Read the user guide: https://www.drupal.org/docs/user_guide/en/index.html",
                "  * Get support: https://www.drupal.org/support",
                "  * Get involved with the Drupal community:",
                "      https://www.drupal.org/getting-involved",
                "  * Remove the plugin that prints this message:",
                "      composer remove drupal/core-project-message"
            ]
        }
    },
    "require-dev": {
        "drupal/core-dev": "^11.3",
        "drush/drush": "^13.7"
    }
}
