# ─────────────────────────────────────────────────────────────────────────────
# Plantilla de variables de PRODUCCIÓN (hosting Plesk).
#
# CÓMO USARLA:
#   1. Copia este fichero a la RAÍZ del proyecto con el nombre .env:
#         cp deploy/env.example ./.env
#   2. Rellena los valores reales más abajo.
#
# El fichero real ./.env está ignorado por git (línea /.env en .gitignore).
# NUNCA lo subas al repositorio: contiene credenciales y el hash_salt.
#
# Lo consume 2-stage-flat.sh al generar el settings.php de producción:
#   - DB_*         -> inject_drupal_db.sh rellena el bloque $databases
#   - HASH_SALT    -> fija $settings['hash_salt'] (prod-only)
#   - TRUSTED_HOST -> fija $settings['trusted_host_patterns'] (prod-only, opcional)
# ─────────────────────────────────────────────────────────────────────────────

# ── Base de datos (requeridas) ───────────────────────────────────────────────
DB_HOST=
DB_PORT=3306
DB_NAME=
DB_USER=
DB_PASSWORD=

# BD opcionales (por defecto: driver mysql, collation utf8mb4_general_ci):
# DB_DRIVER=mysql
# DB_PREFIX=
# DB_COLLATION=utf8mb4_general_ci

# ── hash_salt (requerido) ────────────────────────────────────────────────────
# Valor ESTABLE para producción. Genera uno una sola vez y no lo cambies
# (cambiarlo invalida sesiones y enlaces de un solo uso):
#     openssl rand -hex 32
HASH_SALT=

# ── trusted_host_patterns (opcional, recomendado) ────────────────────────────
# Dominio de producción (sin protocolo). El script lo convierte en el patrón
# ['^tu\.dominio$']. Déjalo vacío para no fijarlo.
#     TRUSTED_HOST=lscm.example.org
TRUSTED_HOST=
