{#
  lscm-master-page — Marco de la landing del máster LSCM.

  COMPONE los componentes ula_* en cada sección, con diseño fiel a la maqueta e
  independiente de Bootstrap Italia.

  - Textos de página: PROPS editables (ver .component.yml). Mapeables a campos de un bloque.
  - Colecciones de ítems: DATOS FIJOS definidos abajo (decisión: contenido casi estático).
  - Botones de salto: por sección, con texto + URL (placeholders editables).
  - Menú hamburguesa y pastillas interactivas: ITERACIÓN POSTERIOR (no incluidos aún).

  Las clases .reveal/.reveal-delay-* (animación al hacer scroll) se mantienen en el marco
  para fidelidad; el JS que las activa es el de la maqueta (lscm-master-page.js).
#}

{# ───────── VALORES POR DEFECTO "DE FÁBRICA" DE LAS PROPS ─────────
   SDC no inyecta de forma fiable los 'default' del .component.yml al renderizar
   vía include() con props parciales. Por eso aquí cada prop de texto toma su
   valor de fábrica con |default() si llega vacía. Esto NO es el contenido
   editable (ese viene de los campos del nodo, vía node--landing.html.twig y
   sobreescribe estos valores); son solo los valores "out of the box" del
   componente, para que se vea completo si no se le pasa nada. #}
{% set logo_url = logo_url|default('/sites/default/files/2026-06/logo-MASTER-LSCM.png') %}
{% set brand_top = brand_top|default('LSCM Master') %}
{% set brand_sub = brand_sub|default('European Joint Programme') %}
{% set hero_badge_text = hero_badge_text|default("Erasmus+ Joint Master's Programme") %}
{% set hero_title = hero_title|default('Shape the Future of') %}
{% set hero_title_highlight = hero_title_highlight|default('European Logistics') %}
{% set hero_description = hero_description|default("A 120 ECTS joint master's degree taught across three European universities. Study in Barcelona, Riga, and specialise in Germany — all in one programme.") %}
{% set hero_cta1_text = hero_cta1_text|default('Apply Now') %}
{% set hero_cta1_url = hero_cta1_url|default('/admission') %}
{% set hero_cta2_text = hero_cta2_text|default('Explore Programme') %}
{% set hero_cta2_url = hero_cta2_url|default('/programme') %}
{% set about_tag = about_tag|default('Master in Logistics & Supply Chain Management') %}
{% set about_title = about_title|default('Integrated. International. Industry-Ready.') %}
{% set about_desc = about_desc|default('A programme designed to train professionals capable of making decisions at operational, tactical, and strategic level — from a holistic and interdisciplinary perspective.') %}
{% set about_cta_text = about_cta_text|default('Learn more about the programme') %}
{% set about_cta_url = about_cta_url|default('/about') %}
{% set journey_tag = journey_tag|default('Your academic path') %}
{% set journey_title = journey_title|default('Four Semesters Across Europe') %}
{% set journey_desc = journey_desc|default('A carefully structured curriculum that builds from core foundations to deep specialisation, moving across three countries.') %}
{% set journey_cta_text = journey_cta_text|default('See full curriculum') %}
{% set journey_cta_url = journey_cta_url|default('/programme') %}
{% set uni_tag = uni_tag|default('Our partner institutions') %}
{% set uni_title = uni_title|default('Three Countries. One Programme.') %}
{% set uni_desc = uni_desc|default('A consortium of established European universities, each contributing their unique expertise and research strengths to the programme.') %}
{% set uni_cta_text = uni_cta_text|default('Meet the partner universities') %}
{% set uni_cta_url = uni_cta_url|default('/partners') %}
{% set spec_tag = spec_tag|default('Choose your track') %}
{% set spec_title = spec_title|default('Two Specialisations, One Qualification') %}
{% set spec_desc = spec_desc|default('Your choice of specialisation in year two shapes your career direction. Both lead to the same joint diploma.') %}
{% set spec_cta_text = spec_cta_text|default('Explore specialisations') %}
{% set spec_cta_url = spec_cta_url|default('/specialisations') %}
{% set adm_tag = adm_tag|default('Admissions') %}
{% set adm_title = adm_title|default('Ready to Apply?') %}
{% set adm_desc = adm_desc|default('Applications are reviewed on a rolling basis. EU applicants are encouraged to apply as early as possible.') %}
{% set adm_cta_text = adm_cta_text|default('See full admission details') %}
{% set adm_cta_url = adm_cta_url|default('/admission') %}
{% set contact_tag = contact_tag|default('Get in touch') %}
{% set contact_title = contact_title|default('Still have questions?') %}
{% set contact_desc = contact_desc|default("Our programme coordinators are happy to help. Reach out before you apply and we'll guide you through the process.") %}
{% set contact_email = contact_email|default('info@master-lscm.eu') %}
{% set contact_faq_text = contact_faq_text|default('Read FAQs') %}
{% set contact_faq_url = contact_faq_url|default('https://master-lscm.eu/faq') %}

{# ───────── DATOS FIJOS DE LAS COLECCIONES (contenido de la maqueta) ───────── #}
{% set hero_stats_default = [
  { number: '120', label: 'ECTS Credits' },
  { number: '3', label: 'Partner Universities' },
  { number: '🇪🇸 🇱🇻 🇩🇪', label: 'Partner Countries' },
  { number: '2', label: 'Specialisations' }
] %}
{% set hero_stats = hero_stats|default(hero_stats_default) %}

{% set about_features = [
  { icon: '🎓', title: 'Accredited Programme', description: 'Verified by legal bodies in all three countries' },
  { icon: '🌍', title: 'International Cohort', description: 'Study alongside students from across Europe' },
  { icon: '🏭', title: 'Industry Links', description: 'Strong ties with logistics companies & consultancies' },
  { icon: '🔬', title: 'Research Focus', description: 'Close connection to academic research projects' },
  { icon: '💼', title: 'Career-Ready', description: 'Practical projects with real companies' },
  { icon: '📄', title: 'PhD Access', description: 'Eligible to continue to doctoral studies' }
] %}

{% set journey_semesters = [
  { semester: 'Semester 1', icon: '📐', university: 'UAB · Barcelona', title: 'Foundations of LSCM', variant: '1',
    subjects: ['Supply Chain Management','Operations Management','Logistics Systems','Quantitative Methods','Information Systems','Project Management'] },
  { semester: 'Semester 2', icon: '🔗', university: 'RTU · Riga', title: 'Advanced Logistics', variant: '2',
    subjects: ['Transport & Distribution','Warehousing','Procurement','Supply Chain Analytics','Lean Management'] },
  { semester: 'Semester 3', icon: '⚙️', university: 'RTU or UASW', title: 'Specialisation', variant: '3',
    subjects: ['Specialisation Track','Electives','Applied Projects'] },
  { semester: 'Semester 4', icon: '📝', university: 'RTU or UASW', title: "Master's Thesis", variant: '4',
    subjects: ['Research Methods','Thesis','Defence'] }
] %}

{% set universities_default = [
  { flag: '🇪🇸', country: 'Spain · Barcelona', name: 'Universitat Autònoma de Barcelona', abbr: 'UAB',
    description: "The lead institution of the LSCM consortium. A top public research university located in the Barcelona metropolitan area — one of Europe's leading logistics hubs. All admissions and enrolment are handled by UAB.",
    tags: [ { label: 'Semester 1' }, { label: 'Lead Partner' } ] },
  { flag: '🇱🇻', country: 'Latvia · Riga', name: 'Riga Technical University', abbr: 'RTU',
    description: 'One of the oldest and largest technical universities in the Baltic states. RTU specialises in engineering, technology, and information systems — bringing a strong technical and digital perspective to the programme.',
    tags: [ { label: 'Semester 2' }, { label: 'Semester 3 & 4 (option)' } ] },
  { flag: '🇩🇪', country: 'Germany · Wildau', name: 'University of Applied Sciences Wildau', abbr: 'UASW',
    description: 'Located near Berlin, UASW is renowned for its applied research in logistics systems engineering. Strong industry connections and a hands-on approach to learning make it ideal for students seeking practical expertise.',
    tags: [ { label: 'Semester 3 & 4 (option)' } ] }
] %}
{# Si llega la prop "universities" (del nodo vía preprocess, ADR-002), se usa;
   si no, el array de fábrica de arriba. #}
{% set universities = universities|default(universities_default) %}

{% set specializations = [
  { icon: '📊', title: 'Logistics Information Systems', university: 'Riga Technical University · Latvia', variant: 'primary',
    description: 'Focus on how integrated IT solutions support and optimise logistics and supply chain management. Ideal for those interested in digitalisation, data-driven decision-making and smart logistics.',
    modules: ['Logistics IT Systems & Architecture','Digital Transformation in SCM','Data Analytics & Business Intelligence','ERP & WMS Systems','IoT & Smart Logistics'] },
  { icon: '🏗️', title: 'Logistics Systems Engineering', university: 'University of Applied Sciences Wildau · Germany', variant: 'secondary',
    description: 'Focus on analysis, design, evaluation and implementation of materials handling, transport, and logistics management and control systems. Hands-on and engineering-oriented.',
    modules: ['Materials Handling Systems','Warehouse Design & Automation','Transport Network Optimisation','Simulation & Modelling','Logistics Control Systems'] }
] %}

{% set why_items_default = [
  { number: '3', title: 'Countries, one degree', description: 'Live, study and build your network in Spain, Latvia, and Germany — with one joint diploma at the end.' },
  { number: '120', title: "ECTS — full master's", description: 'A complete two-year programme that qualifies you for PhD programmes in logistics and engineering.' },
  { number: '2', title: 'Focused specialisations', description: 'Choose a track aligned with your career goals — digital IT systems or engineering implementation.' },
  { number: '∞', title: 'Industry connections', description: 'Real projects, guest lectures, and company visits integrated throughout the programme.' },
  { number: 'EN', title: 'Fully in English', description: 'All courses are taught in English, designed for an international and multicultural student body.' },
  { number: '🇪🇺', title: 'EU accredited', description: 'An officially verified joint programme compliant with European higher education standards.' }
] %}
{% set why_items = why_items|default(why_items_default) %}

{% set timeline_items = [
  { title: '1. Pre-enrolment opens', description: 'January – September each year. Rolling review of applications.' },
  { title: '2. Document submission', description: 'Upload required documents via the UAB online portal. Obtain your student NIA number first if not yet a UAB student.' },
  { title: '3. Admissions committee review', description: 'Decision communicated within 20 days of application submission.' },
  { title: '4. Enrolment & start of studies', description: 'Follow UAB enrolment procedures. Programme begins in September.' }
] %}

{% set requirements_cards = [
  { icon: '🎓', title: 'Academic Background', description: "Bachelor's degree in engineering, technology, business, or a related field from a recognised institution." },
  { icon: '🌐', title: 'English Proficiency', description: 'TOEFL 90+ (internet-based) or equivalent B2 level according to the CEFR framework.' },
  { icon: '📋', title: 'Documents', description: 'CV, motivation letter, academic transcripts, degree certificate, and language certificate.' },
  { icon: '🌍', title: 'Open to EU & non-EU', description: "International students outside the EU are supported through UAB's International Support Service for visa applications." }
] %}

{# ───────────────────────────── NAV ───────────────────────────── #}
<nav>
  <div class="nav-inner">
    <a href="/" class="nav-logo">
      <img src="{{ logo_url }}" alt="{{ brand_top }}" class="nav-logo-img">
      <div class="nav-brand">
        <span class="nav-brand-top">{{ brand_top }}</span>
        <span class="nav-brand-sub">{{ brand_sub }}</span>
      </div>
    </a>
    <ul class="nav-links">
      <li><a href="#about">About</a></li>
      <li><a href="#journey">Programme</a></li>
      <li><a href="#universities">Partners</a></li>
      <li><a href="#specializations">Specialisations</a></li>
      <li><a href="#admission">Admission</a></li>
      <li><a href="{{ hero_cta1_url }}" class="nav-cta">Apply Now</a></li>
    </ul>
  </div>
</nav>

{# ───────────────────────────── HERO ───────────────────────────── #}
<section class="hero">
  <div class="hero-badge">{{ hero_badge_text }}</div>
  <h1>{{ hero_title }}<br><span>{{ hero_title_highlight }}</span></h1>
  <p>{{ hero_description }}</p>
  <div class="hero-btns">
    <a href="#admission" class="btn-primary">{{ hero_cta1_text }} &rarr;</a>
    <a href="#journey" class="btn-outline">{{ hero_cta2_text }}</a>
  </div>
  <div class="hero-stats">
    {% for stat in hero_stats %}
      {{ include('bootstrap_ula_lscm:ula_hero_stat', { number: stat.number, label: stat.label }) }}
    {% endfor %}
  </div>
  <div class="hero-scroll"><div class="scroll-arrow"></div></div>
</section>

{# ───────────────────────────── ABOUT ───────────────────────────── #}
<section class="about" id="about">
  <div class="container">
    <div class="about-grid">
      <div class="about-visual reveal">
        <div class="about-card-main">
          <h3>A programme built for the European labour market</h3>
          <p>The LSCM Master is a joint accredited programme jointly offered by leading European universities. It addresses the most pressing challenges in global supply chain management through technology, engineering, and business — with a deeply international approach.</p>
        </div>
        <div class="about-card-accent">
          <h4>Joint Diploma</h4>
          <p>Official diploma issued by UAB on behalf of all partner universities. Recognised across Europe and grants access to PhD studies.</p>
        </div>
      </div>
      <div>
        <div class="reveal reveal-delay-1">
          <p class="section-tag">{{ about_tag }}</p>
          <h2 class="section-title">{{ about_title }}</h2>
          <p class="section-desc">{{ about_desc }}</p>
        </div>
        <div class="about-features reveal reveal-delay-2">
          {% for f in about_features %}
            {{ include('bootstrap_ula_lscm:ula_feature_item', { icon: f.icon, title: f.title, description: f.description }) }}
          {% endfor %}
        </div>
        <div class="reveal reveal-delay-3" style="margin-top:2rem;">
          <a href="{{ about_cta_url }}" class="btn-primary">{{ about_cta_text }} &rarr;</a>
        </div>
      </div>
    </div>
  </div>
</section>

{# ───────────────────────────── JOURNEY ───────────────────────────── #}
<section class="journey" id="journey">
  <div class="container">
    <div class="journey-header reveal">
      <p class="section-tag">{{ journey_tag }}</p>
      <h2 class="section-title">{{ journey_title }}</h2>
      <p class="section-desc" style="margin: 0 auto;">{{ journey_desc }}</p>
    </div>
    <div class="journey-track">
      {% for sem in journey_semesters %}
        {{ include('bootstrap_ula_lscm:ula_sem_card', {
          semester: sem.semester, icon: sem.icon, university: sem.university,
          title: sem.title, variant: sem.variant, subjects: sem.subjects
        }) }}
        {# Conector decorativo entre tarjetas (no tras la última) — decisión: es del layout #}
        {% if not loop.last %}
          <div class="journey-connector reveal"><div class="connector-line"></div></div>
        {% endif %}
      {% endfor %}
    </div>
    <div style="text-align:center; margin-top:2.5rem;" class="reveal">
      <div class="journey-split-note" style="display:inline-block;">
        <p>🔀 Semesters 3 &amp; 4 — choose your specialisation track: study at <span>RTU (Riga, Latvia)</span> or <span>UASW (Wildau, Germany)</span></p>
      </div>
    </div>
    <div class="reveal" style="text-align:center; margin-top:2rem;">
      <a href="{{ journey_cta_url }}" class="btn-primary">{{ journey_cta_text }} &rarr;</a>
    </div>
  </div>
</section>

{# ───────────────────────────── UNIVERSITIES ───────────────────────────── #}
<section class="universities" id="universities">
  <div class="container">
    <div class="reveal">
      <p class="section-tag">{{ uni_tag }}</p>
      <h2 class="section-title">{{ uni_title }}</h2>
      <p class="section-desc">{{ uni_desc }}</p>
    </div>
    <div class="uni-grid">
      {% for uni in universities %}
        {{ include('bootstrap_ula_lscm:ula_uni_card', {
          flag: uni.flag, country: uni.country, name: uni.name, abbr: uni.abbr,
          description: uni.description, tags: uni.tags
        }) }}
      {% endfor %}
    </div>
    <div class="reveal" style="margin-top:2.5rem;">
      <a href="{{ uni_cta_url }}" class="btn-outline">{{ uni_cta_text }} &rarr;</a>
    </div>
  </div>
</section>

{# ───────────────────────────── SPECIALIZATIONS ───────────────────────────── #}
<section class="specializations" id="specializations">
  <div class="container">
    <div class="spec-header">
      <div class="reveal">
        <p class="section-tag">{{ spec_tag }}</p>
        <h2 class="section-title">{{ spec_title }}</h2>
      </div>
      <p class="section-desc reveal reveal-delay-1" style="max-width: 360px;">{{ spec_desc }}</p>
    </div>
    <div class="spec-grid">
      {% for spec in specializations %}
        {{ include('bootstrap_ula_lscm:ula_spec_card', {
          icon: spec.icon, title: spec.title, university: spec.university,
          description: spec.description, modules: spec.modules, variant: spec.variant
        }) }}
      {% endfor %}
    </div>
    <div class="reveal" style="margin-top:2.5rem; text-align:center;">
      <a href="{{ spec_cta_url }}" class="btn-primary">{{ spec_cta_text }} &rarr;</a>
    </div>
  </div>
</section>

{# ───────────────────────────── WHY ───────────────────────────── #}
<section class="why">
  <div class="container">
    <div class="reveal">
      <p class="section-tag">Why choose LSCM</p>
      <h2 class="section-title" style="color:white;">The LSCM Advantage</h2>
    </div>
    <div class="why-grid">
      {% for item in why_items %}
        {{ include('bootstrap_ula_lscm:ula_why_item', { number: item.number, title: item.title, description: item.description }) }}
      {% endfor %}
    </div>
  </div>
</section>

{# ───────────────────────────── ADMISSION ───────────────────────────── #}
<section class="admission" id="admission">
  <div class="container">
    <div class="admission-grid">
      <div>
        <div class="reveal">
          <p class="section-tag">{{ adm_tag }}</p>
          <h2 class="section-title">{{ adm_title }}</h2>
          <p class="section-desc">{{ adm_desc }}</p>
        </div>
        <div class="timeline reveal reveal-delay-1">
          {% for step in timeline_items %}
            {{ include('bootstrap_ula_lscm:ula_timeline_item', {
              title: step.title, description: step.description, show_line: not loop.last
            }) }}
          {% endfor %}
        </div>
        <div class="reveal" style="margin-top:1rem;">
          <a href="{{ adm_cta_url }}" class="btn-primary">{{ adm_cta_text }} &rarr;</a>
        </div>
      </div>
      <div>
        <p class="section-tag reveal">Requirements</p>
        <div class="req-cards reveal reveal-delay-1">
          {% for req in requirements_cards %}
            {{ include('bootstrap_ula_lscm:ula_req_card', { icon: req.icon, title: req.title, description: req.description }) }}
          {% endfor %}
        </div>
        <div class="req-cta reveal reveal-delay-2">
          <h4>Start your European journey today</h4>
          <p>All admissions are handled by UAB. Click below to begin the pre-enrolment process at the Autonomous University of Barcelona.</p>
          <a href="{{ adm_cta_url }}">Go to Application Portal &rarr;</a>
        </div>
      </div>
    </div>
  </div>
</section>

{# ───────────────────────────── GET IN TOUCH (CTA) ───────────────────────────── #}
<section class="cta-section">
  <div class="container">
    <div class="cta-inner reveal">
      <p class="section-tag">{{ contact_tag }}</p>
      <h2 class="section-title">{{ contact_title }}</h2>
      <p class="section-desc">{{ contact_desc }}</p>
      <div class="cta-btns">
        <a href="mailto:{{ contact_email }}" class="btn-blue">📧 {{ contact_email }}</a>
        <a href="{{ contact_faq_url }}" target="_blank" class="btn-primary">{{ contact_faq_text }} &rarr;</a>
      </div>
    </div>
  </div>
</section>

{# ───────────────────────────── FOOTER ───────────────────────────── #}
<footer>
  <div class="footer-inner">
    <div class="footer-top">
      <div class="footer-brand">
        <span class="nav-brand-top">{{ brand_top }}</span>
        <p>European Joint Master's Programme in Logistics &amp; Supply Chain Management. A consortium of UAB, RTU, and UASW — training the next generation of European logistics leaders.</p>
      </div>
      <div class="footer-col">
        <h5>Programme</h5>
        <ul>
          <li><a href="{{ about_cta_url }}">About the Master</a></li>
          <li><a href="{{ journey_cta_url }}">Academic Path</a></li>
          <li><a href="{{ spec_cta_url }}">Specialisations</a></li>
          <li><a href="{{ uni_cta_url }}">Partner Universities</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h5>Admissions</h5>
        <ul>
          <li><a href="{{ adm_cta_url }}">How to Apply</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h5>Partners</h5>
        <ul>
          <li><a href="https://www.uab.cat" target="_blank">UAB Barcelona</a></li>
          <li><a href="https://www.rtu.lv" target="_blank">RTU Riga</a></li>
          <li><a href="https://en.th-wildau.de" target="_blank">UASW Wildau</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <p>© 2025 Master in Logistics &amp; Supply Chain Management. All rights reserved.</p>
      <div class="eu-badge">
        <span>🇪🇺</span>
        <span>Supported by the European Union · Erasmus+ Programme</span>
      </div>
    </div>
  </div>
</footer>
