{#
  EJEMPLO DE USO del componente lscm-master-page
  ──────────────────────────────────────────────
  Coloca este snippet en la plantilla Drupal que quiera incluir
  el componente (p.ej. page--front.html.twig o un paragraph template).

  Todos los valores hardcoded del HTML original quedan aquí como
  props (strings simples) o slots (bloques HTML con estructura).
#}

{% embed 'bootstrap_ula_lscm:lscm-master-page' with {

  site_name:      'LSCM Master',
  site_subtitle:  'European Joint Programme',
  nav_cta_text:   'Apply Now',
  nav_cta_url:    '#admission',


  hero_badge_text:          'Erasmus+ Joint Master\'s Programme',
  hero_title:               'Shape the Future of',
  hero_title_highlight:     'European Logistics',
  hero_description:         'A 120 ECTS joint master\'s degree taught across three European universities. Study in Barcelona, Riga, and specialise in Germany — all in one programme.',
  hero_cta_primary_text:    'Apply Now',
  hero_cta_primary_url:     '#admission',
  hero_cta_secondary_text:  'Explore Programme',
  hero_cta_secondary_url:   '#journey',


  about_card_title:    'A programme built for the European labour market',
  about_card_body:     'The LSCM Master is a joint accredited programme jointly offered by leading European universities. It addresses the most pressing challenges in global supply chain management through technology, engineering, and business — with a deeply international approach.',
  about_accent_title:  'Joint Diploma',
  about_accent_body:   'Official diploma issued by UAB on behalf of all partner universities. Recognised across Europe and grants access to PhD studies.',
  about_section_tag:   'Master in Logistics & Supply Chain Management',
  about_section_title: 'Integrated. International. Industry-Ready.',
  about_section_desc:  'A programme designed to train professionals capable of making decisions at operational, tactical, and strategic level — from a holistic and interdisciplinary perspective.',


  journey_section_tag:   'Your academic path',
  journey_section_title: 'Four Semesters Across Europe',
  journey_section_desc:  'A carefully structured curriculum that builds from core foundations to deep specialisation, moving across three countries.',
  journey_split_note:    '🔀 Semesters 3 & 4 — choose your specialisation track: study at <span>RTU (Riga, Latvia)</span> or <span>UASW (Wildau, Germany)</span>',


  universities_section_tag:   'Our partner institutions',
  universities_section_title: 'Three Countries. One Programme.',
  universities_section_desc:  'A consortium of established European universities, each contributing their unique expertise and research strengths to the programme.',


  spec_section_tag:   'Choose your track',
  spec_section_title: 'Two Specialisations, One Qualification',
  spec_section_desc:  'Your choice of specialisation in year two shapes your career direction. Both lead to the same joint diploma.',


  why_section_tag:   'Why choose LSCM',
  why_section_title: 'The LSCM Advantage',


  admission_section_tag:   'Admissions',
  admission_section_title: 'Ready to Apply?',
  admission_section_desc:  'Applications are reviewed on a rolling basis. EU applicants are encouraged to apply as early as possible.',
  requirements_tag:        'Requirements',
  req_cta_title:           'Start your European journey today',
  req_cta_desc:            'All admissions are handled by UAB. Click below to begin the pre-enrolment process at the Autonomous University of Barcelona.',
  req_cta_url:             'https://master-lscm.eu/enrollment',
  req_cta_button_text:     'Go to Application Portal',


  cta_section_tag:   'Get in touch',
  cta_section_title: 'Still have questions?',
  cta_section_desc:  'Our programme coordinators are happy to help. Reach out before you apply and we\'ll guide you through the process.',
  cta_email:         'info@master-lscm.eu',
  cta_faq_url:       'https://master-lscm.eu/faq',
  cta_faq_text:      'Read FAQs',

  footer_brand_name:    'LSCM Master',
  footer_brand_desc:    'European Joint Master\'s Programme in Logistics & Supply Chain Management. A consortium of UAB, RTU, and UASW — training the next generation of European logistics leaders.',
  footer_col1_title:    'Programme',
  footer_col2_title:    'Admissions',
  footer_col3_title:    'Partners',
  footer_copyright:     '© 2025 Master in Logistics & Supply Chain Management. All rights reserved.',
  footer_eu_badge_text: 'Supported by the European Union · Erasmus+ Programme',

} only %}

  {# ── SLOT: nav_links ─────────────────────────────────────── #}
  {% block nav_links %}
    <li><a href="#about">About</a></li>
    <li><a href="#journey">Programme</a></li>
    <li><a href="#universities">Partners</a></li>
    <li><a href="#specializations">Specialisations</a></li>
    <li><a href="#admission">Admission</a></li>
  {% endblock %}

  {# ── SLOT: hero_stats ────────────────────────────────────── #}
  {% block hero_stats %}
    <div class="hero-stat">
      <span class="hero-stat-num">120</span>
      <span class="hero-stat-label">ECTS Credits</span>
    </div>
    <div class="hero-stat">
      <span class="hero-stat-num">3</span>
      <span class="hero-stat-label">Partner Universities</span>
    </div>
    <div class="hero-stat">
      <span class="hero-stat-label" style="font-size:10px;margin-top:0;">STUDY IN</span>
      <span class="hero-stat-num" style="font-size:1.5rem;">🇪🇸 🇱🇻 🇩🇪</span>
    </div>
    <div class="hero-stat">
      <span class="hero-stat-num">2</span>
      <span class="hero-stat-label">Specialisations</span>
    </div>
  {% endblock %}

  {# ── SLOT: about_features ────────────────────────────────── #}
  {% block about_features %}
    <div class="feature-item">
      <div class="feature-icon">🎓</div>
      <div class="feature-text">
        <strong>Accredited Programme</strong>
        <span>Verified by legal bodies in all three countries</span>
      </div>
    </div>
    <div class="feature-item">
      <div class="feature-icon">🌍</div>
      <div class="feature-text">
        <strong>International Cohort</strong>
        <span>Study alongside students from across Europe</span>
      </div>
    </div>
    <div class="feature-item">
      <div class="feature-icon">🏭</div>
      <div class="feature-text">
        <strong>Industry Links</strong>
        <span>Strong ties with logistics companies &amp; consultancies</span>
      </div>
    </div>
    <div class="feature-item">
      <div class="feature-icon">🔬</div>
      <div class="feature-text">
        <strong>Research Focus</strong>
        <span>Close connection to academic research projects</span>
      </div>
    </div>
    <div class="feature-item">
      <div class="feature-icon">💼</div>
      <div class="feature-text">
        <strong>Career-Ready</strong>
        <span>Practical projects with real companies</span>
      </div>
    </div>
    <div class="feature-item">
      <div class="feature-icon">📄</div>
      <div class="feature-text">
        <strong>PhD Access</strong>
        <span>Eligible to continue to doctoral studies</span>
      </div>
    </div>
  {% endblock %}


  {% block journey_semesters %}
    <div class="sem-card reveal">
      <div class="sem-num">Semester 1</div>
      <div class="sem-icon sem-icon-1">📐</div>
      <span class="sem-uni">UAB · Barcelona</span>
      <h3>Foundations of LSCM</h3>
      <ul class="sem-subjects">
        <li>Supply Chain Management</li>
        <li>Operations Management</li>
        <li>Logistics Systems</li>
        <li>Quantitative Methods</li>
        <li>Information Systems</li>
        <li>Project Management</li>
      </ul>
    </div>
    <div class="journey-connector reveal"><div class="connector-line"></div></div>

    <div class="sem-card reveal reveal-delay-1">
      <div class="sem-num">Semester 2</div>
      <div class="sem-icon sem-icon-2">🔗</div>
      <span class="sem-uni sem-uni-2">RTU · Riga</span>
      <h3>Advanced LSCM Concepts</h3>
      <ul class="sem-subjects">
        <li>Advanced Supply Chain Strategy</li>
        <li>Transport &amp; Distribution</li>
        <li>Procurement &amp; Sourcing</li>
        <li>Sustainability in Logistics</li>
        <li>Financial Aspects of LSCM</li>
        <li>Data Analysis &amp; Modelling</li>
      </ul>
    </div>
    <div class="journey-connector reveal reveal-delay-1"><div class="connector-line"></div></div>

    <div class="sem-card reveal reveal-delay-2">
      <div class="sem-num">Semester 3</div>
      <div class="sem-icon sem-icon-3">⚙️</div>
      <span class="sem-uni sem-uni-3">RTU or UASW</span>
      <h3>Specialisation</h3>
      <ul class="sem-subjects">
        <li>Chosen specialisation track</li>
        <li>Advanced elective modules</li>
        <li>Industry project</li>
        <li>Research methodology</li>
        <li>Guest lectures &amp; seminars</li>
      </ul>
    </div>
    <div class="journey-connector reveal reveal-delay-2"><div class="connector-line"></div></div>

    <div class="sem-card reveal reveal-delay-3">
      <div class="sem-num">Semester 4</div>
      <div class="sem-icon sem-icon-4">📝</div>
      <span class="sem-uni sem-uni-4">RTU or UASW</span>
      <h3>Master's Thesis</h3>
      <ul class="sem-subjects">
        <li>Master's thesis project</li>
        <li>Supervised by academia</li>
        <li>Industry collaboration</li>
        <li>Final defence &amp; presentation</li>
      </ul>
    </div>
  {% endblock %}

  {# ── SLOT: universities ──────────────────────────────────── #}
  {% block universities %}
    <div class="uni-card reveal reveal-delay-1">
      <div class="uni-country"><span class="uni-flag">🇪🇸</span> Spain · Barcelona</div>
      <h3>Universitat Autònoma de Barcelona</h3>
      <div class="uni-abbr">UAB</div>
      <p>The lead institution of the LSCM consortium. A top public research university located in the Barcelona metropolitan area — one of Europe's leading logistics hubs. All admissions and enrolment are handled by UAB.</p>
      <div class="uni-semesters">
        <span class="uni-sem-tag">Semester 1</span>
        <span class="uni-sem-tag">Lead Partner</span>
      </div>
    </div>
    <div class="uni-card reveal reveal-delay-2">
      <div class="uni-country"><span class="uni-flag">🇱🇻</span> Latvia · Riga</div>
      <h3>Riga Technical University</h3>
      <div class="uni-abbr">RTU</div>
      <p>One of the oldest and largest technical universities in the Baltic states. RTU specialises in engineering, technology, and information systems — bringing a strong technical and digital perspective to the programme.</p>
      <div class="uni-semesters">
        <span class="uni-sem-tag">Semester 2</span>
        <span class="uni-sem-tag">Semester 3 &amp; 4 (option)</span>
      </div>
    </div>
    <div class="uni-card reveal reveal-delay-3">
      <div class="uni-country"><span class="uni-flag">🇩🇪</span> Germany · Wildau</div>
      <h3>University of Applied Sciences Wildau</h3>
      <div class="uni-abbr">UASW</div>
      <p>Located near Berlin, UASW is renowned for its applied research in logistics systems engineering. Strong industry connections and a hands-on approach to learning make it ideal for students seeking practical expertise.</p>
      <div class="uni-semesters">
        <span class="uni-sem-tag">Semester 3 &amp; 4 (option)</span>
      </div>
    </div>
  {% endblock %}

  {# ── SLOT: specializations ───────────────────────────────── #}
  {% block specializations %}
    <div class="spec-card reveal">
      <div class="spec-top">
        <div class="spec-icon">📊</div>
        <h3>Logistics Information Systems</h3>
        <div class="spec-uni">Riga Technical University · Latvia</div>
      </div>
      <div class="spec-body">
        <p>Focus on how integrated IT solutions support and optimise logistics and supply chain management. Ideal for those interested in digitalisation, data-driven decision-making and smart logistics.</p>
        <ul class="spec-modules">
          <li>Logistics IT Systems &amp; Architecture</li>
          <li>Digital Transformation in SCM</li>
          <li>Data Analytics &amp; Business Intelligence</li>
          <li>ERP &amp; WMS Systems</li>
          <li>IoT &amp; Smart Logistics</li>
        </ul>
      </div>
    </div>
    <div class="spec-card reveal reveal-delay-2">
      <div class="spec-top spec-top-2">
        <div class="spec-icon">🏗️</div>
        <h3>Logistics Systems Engineering</h3>
        <div class="spec-uni">University of Applied Sciences Wildau · Germany</div>
      </div>
      <div class="spec-body">
        <p>Focus on analysis, design, evaluation and implementation of materials handling, transport, and logistics management and control systems. Hands-on and engineering-oriented.</p>
        <ul class="spec-modules">
          <li>Materials Handling Systems</li>
          <li>Warehouse Design &amp; Automation</li>
          <li>Transport Network Optimisation</li>
          <li>Simulation &amp; Modelling</li>
          <li>Logistics Control Systems</li>
        </ul>
      </div>
    </div>
  {% endblock %}

  {# ── SLOT: why_items ─────────────────────────────────────── #}
  {% block why_items %}
    <div class="why-item reveal reveal-delay-1">
      <div class="why-num">3</div>
      <h4>Countries, one degree</h4>
      <p>Live, study and build your network in Spain, Latvia, and Germany — with one joint diploma at the end.</p>
    </div>
    <div class="why-item reveal reveal-delay-2">
      <div class="why-num">120</div>
      <h4>ECTS — full master's</h4>
      <p>A complete two-year programme that qualifies you for PhD programmes in logistics and engineering.</p>
    </div>
    <div class="why-item reveal reveal-delay-3">
      <div class="why-num">2</div>
      <h4>Focused specialisations</h4>
      <p>Choose a track aligned with your career goals — digital IT systems or engineering implementation.</p>
    </div>
    <div class="why-item reveal reveal-delay-1">
      <div class="why-num">∞</div>
      <h4>Industry connections</h4>
      <p>Real projects, guest lectures, and company visits integrated throughout the programme.</p>
    </div>
    <div class="why-item reveal reveal-delay-2">
      <div class="why-num">EN</div>
      <h4>Fully in English</h4>
      <p>All courses are taught in English, designed for an international and multicultural student body.</p>
    </div>
    <div class="why-item reveal reveal-delay-3">
      <div class="why-num">🇪🇺</div>
      <h4>EU accredited</h4>
      <p>An officially verified joint programme compliant with European higher education standards.</p>
    </div>
  {% endblock %}

  {# ── SLOT: timeline_items ────────────────────────────────── #}
  {% block timeline_items %}
    <div class="timeline-item">
      <div class="timeline-left">
        <div class="timeline-dot"></div>
        <div class="timeline-line"></div>
      </div>
      <div class="timeline-content">
        <h4>1. Pre-enrolment opens</h4>
        <p>January – September each year. Rolling review of applications.</p>
      </div>
    </div>
    <div class="timeline-item">
      <div class="timeline-left">
        <div class="timeline-dot"></div>
        <div class="timeline-line"></div>
      </div>
      <div class="timeline-content">
        <h4>2. Document submission</h4>
        <p>Upload required documents via the UAB online portal. Obtain your student NIA number first if not yet a UAB student.</p>
      </div>
    </div>
    <div class="timeline-item">
      <div class="timeline-left">
        <div class="timeline-dot"></div>
        <div class="timeline-line"></div>
      </div>
      <div class="timeline-content">
        <h4>3. Admissions committee review</h4>
        <p>Decision communicated within 20 days of application submission.</p>
      </div>
    </div>
    <div class="timeline-item">
      <div class="timeline-left">
        <div class="timeline-dot"></div>
      </div>
      <div class="timeline-content">
        <h4>4. Enrolment &amp; start of studies</h4>
        <p>Follow UAB enrolment procedures. Programme begins in September.</p>
      </div>
    </div>
  {% endblock %}

  {# ── SLOT: requirements_cards ────────────────────────────── #}
  {% block requirements_cards %}
    <div class="req-card">
      <div class="req-card-icon">🎓</div>
      <h4>Academic Background</h4>
      <p>Bachelor's degree in engineering, technology, business, or a related field from a recognised institution.</p>
    </div>
    <div class="req-card">
      <div class="req-card-icon">🌐</div>
      <h4>English Proficiency</h4>
      <p>TOEFL 90+ (internet-based) or equivalent B2 level according to the CEFR framework.</p>
    </div>
    <div class="req-card">
      <div class="req-card-icon">📋</div>
      <h4>Documents</h4>
      <p>CV, motivation letter, academic transcripts, degree certificate, and language certificate.</p>
    </div>
    <div class="req-card">
      <div class="req-card-icon">🌍</div>
      <h4>Open to EU &amp; non-EU</h4>
      <p>International students outside the EU are supported through UAB's International Support Service for visa applications.</p>
    </div>
  {% endblock %}

  {# ── SLOT: footer_col1_links ─────────────────────────────── #}
  {% block footer_col1_links %}
    <li><a href="#about">About the Master</a></li>
    <li><a href="#journey">Academic Path</a></li>
    <li><a href="#specializations">Specialisations</a></li>
    <li><a href="#universities">Partner Universities</a></li>
  {% endblock %}

  {# ── SLOT: footer_col2_links ─────────────────────────────── #}
  {% block footer_col2_links %}
    <li><a href="#admission">How to Apply</a></li>
    <li><a href="https://master-lscm.eu/enrollment" target="_blank">Application Portal</a></li>
    <li><a href="https://master-lscm.eu/faq" target="_blank">FAQ</a></li>
    <li><a href="mailto:info@master-lscm.eu">Contact Us</a></li>
  {% endblock %}

  {# ── SLOT: footer_col3_links ─────────────────────────────── #}
  {% block footer_col3_links %}
    <li><a href="https://www.uab.cat" target="_blank">UAB Barcelona</a></li>
    <li><a href="https://www.rtu.lv" target="_blank">RTU Riga</a></li>
    <li><a href="https://en.th-wildau.de" target="_blank">UASW Wildau</a></li>
  {% endblock %}

{% endembed %}
