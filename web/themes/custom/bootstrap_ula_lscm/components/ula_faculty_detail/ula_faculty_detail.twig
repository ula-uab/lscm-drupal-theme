{#
  ula_faculty_detail — ficha de detalle de un Faculty member (bloque main content).

  Componente bespoke alimentado por PROPS tipados (no slots): el markup vive aquí; el
  preprocess solo prepara datos limpios (valores crudos). Cada bloque se pinta solo si su
  prop trae valor (guards por presencia), porque casi todos los campos son opcionales.

  'bio' se imprime con |raw porque es HTML saneado (Basic HTML), no texto plano.

  Autónomo: sin markup ni clases de Bootstrap Italia. Colores y tipografía, de
  ula-tokens.css (librería global) y del CSS propio del componente.
#}
<article class="ula-faculty-detail">

  {# ── Cabecera: retrato + identidad ── #}
  <header class="ula-faculty-detail__header">
    {% if photo_url %}
      <img class="ula-faculty-detail__portrait" src="{{ photo_url }}" alt="{{ name }}">
    {% else %}
      <div class="ula-faculty-detail__portrait ula-faculty-detail__portrait--placeholder" aria-hidden="true">{{ initials }}</div>
    {% endif %}

    <div class="ula-faculty-detail__identity">
      <span class="ula-faculty-detail__eyebrow">Faculty member</span>
      <h1 class="ula-faculty-detail__name">{{ name }}</h1>
      {% if academic_title %}
        <p class="ula-faculty-detail__academic-title">{{ academic_title }}</p>
      {% endif %}

      {% if positions or roles %}
        <div class="ula-faculty-detail__pills">
          {% for position in positions %}
            <span class="ula-faculty-detail__pill ula-faculty-detail__pill--position">{{ position }}</span>
          {% endfor %}
          {% for role in roles %}
            <span class="ula-faculty-detail__pill ula-faculty-detail__pill--role">{{ role }}</span>
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </header>

  {# ── Cuerpo: columna principal + rail ── #}
  <div class="ula-faculty-detail__body">

    <main class="ula-faculty-detail__main">
      {% if bio %}
        <section class="ula-faculty-detail__card">
          <h2 class="ula-faculty-detail__label">Biography</h2>
          <div class="ula-faculty-detail__bio">{{ bio|raw }}</div>
        </section>
      {% endif %}

      {% if expertise or application_areas %}
        <section class="ula-faculty-detail__card">
          {% if expertise %}
            <div class="ula-faculty-detail__taxo">
              <h2 class="ula-faculty-detail__label">Expertise</h2>
              <div class="ula-faculty-detail__chips">
                {% for term in expertise %}
                  <span class="ula-faculty-detail__chip">{{ term }}</span>
                {% endfor %}
              </div>
            </div>
          {% endif %}
          {% if application_areas %}
            <div class="ula-faculty-detail__taxo">
              <h2 class="ula-faculty-detail__label">Application areas</h2>
              <div class="ula-faculty-detail__chips">
                {% for term in application_areas %}
                  <span class="ula-faculty-detail__chip">{{ term }}</span>
                {% endfor %}
              </div>
            </div>
          {% endif %}
        </section>
      {% endif %}

      {% if courses %}
        <section class="ula-faculty-detail__card">
          <h2 class="ula-faculty-detail__label">Courses taught</h2>
          <ul class="ula-faculty-detail__courses">
            {% for course in courses %}
              <li><a href="{{ course.url }}">{{ course.title }}</a></li>
            {% endfor %}
          </ul>
        </section>
      {% endif %}
    </main>

    <aside class="ula-faculty-detail__rail">
      <div class="ula-faculty-detail__card">

        {% if email %}
          <div class="ula-faculty-detail__rail-block">
            <h2 class="ula-faculty-detail__label">Contact</h2>
            <div class="ula-faculty-detail__linklist">
              <a class="ula-faculty-detail__link" href="mailto:{{ email }}">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg>
                {{ email }}
              </a>
            </div>
          </div>
        {% endif %}

        {% if website or linkedin %}
          <div class="ula-faculty-detail__rail-block">
            <h2 class="ula-faculty-detail__label">Links</h2>
            <div class="ula-faculty-detail__linklist">
              {% if website %}
                <a class="ula-faculty-detail__link" href="{{ website }}">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3a15 15 0 0 1 0 18M12 3a15 15 0 0 0 0 18"/></svg>
                  Personal website
                </a>
              {% endif %}
              {% if linkedin %}
                <a class="ula-faculty-detail__link" href="{{ linkedin }}">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M4.98 3.5A2.5 2.5 0 1 0 5 8.5a2.5 2.5 0 0 0 0-5zM3 9h4v12H3zM9 9h3.8v1.7h.05c.53-1 1.83-2.05 3.76-2.05 4 0 4.74 2.64 4.74 6.08V21H17.5v-5.4c0-1.29-.02-2.95-1.8-2.95-1.8 0-2.07 1.4-2.07 2.85V21H9z"/></svg>
                  LinkedIn
                </a>
              {% endif %}
            </div>
          </div>
        {% endif %}

        {% if research_profiles %}
          <div class="ula-faculty-detail__rail-block">
            <h2 class="ula-faculty-detail__label">Research profiles</h2>
            <div class="ula-faculty-detail__linklist">
              {% for profile in research_profiles %}
                <a class="ula-faculty-detail__link" href="{{ profile.url }}">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M12 8v8M9 8h3.5a2 2 0 0 1 0 4H9"/></svg>
                  {{ profile.label }}
                </a>
              {% endfor %}
            </div>
          </div>
        {% endif %}

        {% if affiliation and (affiliation.department or affiliation.university_name or affiliation.location) %}
          <div class="ula-faculty-detail__rail-block">
            <h2 class="ula-faculty-detail__label">Affiliation</h2>
            {% if affiliation.department %}
              <p class="ula-faculty-detail__affil-dept">{{ affiliation.department }}</p>
            {% endif %}
            {% if affiliation.university_name %}
              <p class="ula-faculty-detail__affil-uni">
                {% if affiliation.university_url %}
                  <a href="{{ affiliation.university_url }}">{{ affiliation.university_name }}</a>
                {% else %}
                  <span class="ula-faculty-detail__affil-uni-plain">{{ affiliation.university_name }}</span>
                {% endif %}
              </p>
            {% endif %}
            {% if affiliation.location %}
              <span class="ula-faculty-detail__affil-loc">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 21s-6-5.7-6-10a6 6 0 1112 0c0 4.3-6 10-6 10z"/><circle cx="12" cy="11" r="2"/></svg>
                {{ affiliation.location }}
              </span>
            {% endif %}
          </div>
        {% endif %}

        <div class="ula-faculty-detail__rail-block">
          <h2 class="ula-faculty-detail__label">Status</h2>
          {% if active %}
            <div class="ula-faculty-detail__status"><span class="ula-faculty-detail__dot"></span> Currently teaching</div>
          {% else %}
            <div class="ula-faculty-detail__status"><span class="ula-faculty-detail__dot ula-faculty-detail__dot--off"></span> Not currently teaching</div>
          {% endif %}
        </div>

      </div>
    </aside>

  </div>
</article>
