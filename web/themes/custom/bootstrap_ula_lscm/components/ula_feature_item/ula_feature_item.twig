{#
  ula_feature_item — ítem de features de la sección About.
  Props: icon, title, description. Markup y clases idénticos a la maqueta.
#}
<div class="feature-item">
  <div class="feature-icon">{{ icon }}</div>
  <div class="feature-text">
    <strong>{{ title }}</strong>
    <span>{{ description }}</span>
  </div>
</div>
