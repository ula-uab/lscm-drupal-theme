{#
  ula_uni_card — tarjeta de universidad socia.
  Props: flag, country, name, abbr, description, tags (array de {label, info}).

  Pastillas (tags): si una pastilla tiene 'info' (texto de modal), se renderiza como
  BOTÓN que abre un modal compartido (<dialog> en el marco lscm-master-page) con ese
  contenido. Si no tiene 'info', se renderiza como etiqueta estática (.uni-sem-tag).
  El contenido del modal viaja en un atributo data-modal-html (HTML saneado por Basic
  HTML); el JS del marco lo vuelca en el <dialog> al pulsar. Interactividad con API
  nativa (<dialog>), sin frameworks. Ver ADR-004 / §5.3 (sub-hito 4b).
#}
<div class="uni-card">
  <div class="uni-country"><span class="uni-flag">{{ flag }}</span> {{ country }}</div>
  <h3>{{ name }}</h3>
  <div class="uni-abbr">{{ abbr }}</div>
  <p>{{ description }}</p>
  {% if tags is not empty %}
    <div class="uni-semesters">
      {% for tag in tags %}
        {% set tag_label = tag.label is defined ? tag.label : tag %}
        {% set tag_info = tag.info is defined ? tag.info : '' %}
        {% if tag_info is not empty %}
          <button type="button" class="uni-sem-tag uni-sem-tag--button"
                  data-modal-title="{{ tag_label }}"
                  data-modal-html="{{ tag_info|e('html_attr') }}">
            {{ tag_label }}
          </button>
        {% else %}
          <span class="uni-sem-tag">{{ tag_label }}</span>
        {% endif %}
      {% endfor %}
    </div>
  {% endif %}
</div>
