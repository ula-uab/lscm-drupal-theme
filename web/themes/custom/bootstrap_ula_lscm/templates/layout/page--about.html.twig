{#
/**
 * @file
 * page--about.html.twig — Plantilla de la página /about con MARCO PROPIO.
 *
 * Captura SOLO la ruta /about (sugerencia page--about, verificada): Drupal usa esta
 * plantilla en lugar del page.html.twig de Bootstrap Italia, sin afectar a las demás
 * páginas heredadas (que siguen con BI) ni a la home (page--front).
 *
 * Monta el marco compartido de las páginas de contenido, independiente de BI:
 *   - lscm_page_header  (estética home, navegación de sitio desde el menú 'main')
 *   - {{ page.content }} (el contenido de la página, servido por su vista)
 *   - lscm_page_footer  (provisional)
 *
 * Las variables del header/footer (header_*, footer_*) las inyecta
 * bootstrap_ula_lscm_preprocess_page() en el .theme.
 *
 * NOTA (Fase 1, Opción 1): de momento el "hueco" de contenido es {{ page.content }}
 * tal cual lo sirva la vista heredada; el contenido propio de About es trabajo posterior.
 * Esta plantilla valida el MARCO de forma aislada.
 */
#}
<div class="lscm-page" id="lscm-page--about">

  {{ include('bootstrap_ula_lscm:lscm_page_header', {
    logo_url: header_logo_url,
    brand_top: header_brand_top,
    brand_sub: header_brand_sub,
    menu_links: header_menu_links,
    active_url: header_active_url,
  }, with_context = false) }}

  <main class="lscm-page__content" id="main-content" role="main">

    {# Mensajes del sistema (errores, avisos). Se conservan siempre. #}
    {% if page.highlighted %}
      {{ page.highlighted }}
    {% endif %}

    {# Contenido de la página (servido por su vista). #}
    {{ page.content }}

  </main>

  {{ include('bootstrap_ula_lscm:lscm_page_footer', {
    brand_top: footer_brand_top,
    contact_email: footer_contact_email,
  }, with_context = false) }}

</div>
