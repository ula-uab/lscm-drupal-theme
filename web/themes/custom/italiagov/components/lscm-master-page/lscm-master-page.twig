{#
  Component: lscm-master-page
  Props:   ver lscm-master-page.component.yml
  Slots:   ver lscm-master-page.component.yml
#}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ site_name }} — European Master in Logistics &amp; Supply Chain Management</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Manrope:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>

{# ─────────────────────────────────────────────
   NAV
───────────────────────────────────────────── #}
<nav>
  <div class="nav-inner">
    <a href="#" class="nav-logo">
      {# EU Stars SVG — decorativo, sin contenido editable #}
      <svg class="eu-stars" viewBox="0 0 38 38" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="19" cy="19" r="19" fill="#003399"/>
        <g fill="#FFCC00">
          <polygon points="19,4 19.6,6.2 21.9,6.2 20.1,7.5 20.7,9.7 19,8.4 17.3,9.7 17.9,7.5 16.1,6.2 18.4,6.2" transform="rotate(0 19 19) translate(0,-6)"/>
          <polygon points="19,4 19.6,6.2 21.9,6.2 20.1,7.5 20.7,9.7 19,8.4 17.3,9.7 17.9,7.5 16.1,6.2 18.4,6.2" transform="rotate(30 19 19) translate(0,-6)"/>
          <polygon points="19,4 19.6,6.2 21.9,6.2 20.1,7.5 20.7,9.7 19,8.4 17.3,9.7 17.9,7.5 16.1,6.2 18.4,6.2" transform="rotate(60 19 19) translate(0,-6)"/>
          <polygon points="19,4 19.6,6.2 21.9,6.2 20.1,7.5 20.7,9.7 19,8.4 17.3,9.7 17.9,7.5 16.1,6.2 18.4,6.2" transform="rotate(90 19 19) translate(0,-6)"/>
          <polygon points="19,4 19.6,6.2 21.9,6.2 20.1,7.5 20.7,9.7 19,8.4 17.3,9.7 17.9,7.5 16.1,6.2 18.4,6.2" transform="rotate(120 19 19) translate(0,-6)"/>
          <polygon points="19,4 19.6,6.2 21.9,6.2 20.1,7.5 20.7,9.7 19,8.4 17.3,9.7 17.9,7.5 16.1,6.2 18.4,6.2" transform="rotate(150 19 19) translate(0,-6)"/>
          <polygon points="19,4 19.6,6.2 21.9,6.2 20.1,7.5 20.7,9.7 19,8.4 17.3,9.7 17.9,7.5 16.1,6.2 18.4,6.2" transform="rotate(180 19 19) translate(0,-6)"/>
          <polygon points="19,4 19.6,6.2 21.9,6.2 20.1,7.5 20.7,9.7 19,8.4 17.3,9.7 17.9,7.5 16.1,6.2 18.4,6.2" transform="rotate(210 19 19) translate(0,-6)"/>
          <polygon points="19,4 19.6,6.2 21.9,6.2 20.1,7.5 20.7,9.7 19,8.4 17.3,9.7 17.9,7.5 16.1,6.2 18.4,6.2" transform="rotate(240 19 19) translate(0,-6)"/>
          <polygon points="19,4 19.6,6.2 21.9,6.2 20.1,7.5 20.7,9.7 19,8.4 17.3,9.7 17.9,7.5 16.1,6.2 18.4,6.2" transform="rotate(270 19 19) translate(0,-6)"/>
          <polygon points="19,4 19.6,6.2 21.9,6.2 20.1,7.5 20.7,9.7 19,8.4 17.3,9.7 17.9,7.5 16.1,6.2 18.4,6.2" transform="rotate(300 19 19) translate(0,-6)"/>
          <polygon points="19,4 19.6,6.2 21.9,6.2 20.1,7.5 20.7,9.7 19,8.4 17.3,9.7 17.9,7.5 16.1,6.2 18.4,6.2" transform="rotate(330 19 19) translate(0,-6)"/>
        </g>
      </svg>
      <div class="nav-brand">
        <span class="nav-brand-top">{{ site_name }}</span>
        {% if site_subtitle %}
          <span class="nav-brand-sub">{{ site_subtitle }}</span>
        {% endif %}
      </div>
    </a>

    <ul class="nav-links">
      {# Slot: enlaces internos del menú como <li> items #}
      {{ nav_links }}

      {% if nav_cta_url and nav_cta_text %}
        <li>
          <a href="{{ nav_cta_url }}" class="nav-cta">{{ nav_cta_text }}</a>
        </li>
      {% endif %}
    </ul>
  </div>
</nav>

{# ─────────────────────────────────────────────
   HERO
───────────────────────────────────────────── #}
<section class="hero">
  {% if hero_badge_text %}
    <div class="hero-badge">{{ hero_badge_text }}</div>
  {% endif %}

  <h1>
    {{ hero_title }}<br>
    {% if hero_title_highlight %}
      <span>{{ hero_title_highlight }}</span>
    {% endif %}
  </h1>

  {% if hero_description %}
    <p>{{ hero_description }}</p>
  {% endif %}

  <div class="hero-btns">
    {% if hero_cta_primary_url and hero_cta_primary_text %}
      <a href="{{ hero_cta_primary_url }}" class="btn-primary">{{ hero_cta_primary_text }} &rarr;</a>
    {% endif %}
    {% if hero_cta_secondary_url and hero_cta_secondary_text %}
      <a href="{{ hero_cta_secondary_url }}" class="btn-outline">{{ hero_cta_secondary_text }}</a>
    {% endif %}
  </div>

  {% if hero_stats %}
    <div class="hero-stats">
      {# Slot: bloques .hero-stat con .hero-stat-num y .hero-stat-label #}
      {{ hero_stats }}
    </div>
  {% endif %}

  <div class="hero-scroll">
    <div class="scroll-arrow"></div>
  </div>
</section>

{# ─────────────────────────────────────────────
   ABOUT
───────────────────────────────────────────── #}
<section class="about" id="about">
  <div class="container">
    <div class="about-grid">

      {# Columna izquierda: tarjetas visuales #}
      <div class="about-visual reveal">
        {% if about_card_title or about_card_body %}
          <div class="about-card-main">
            {% if about_card_title %}
              <h3>{{ about_card_title }}</h3>
            {% endif %}
            {% if about_card_body %}
              <p>{{ about_card_body }}</p>
            {% endif %}
          </div>
        {% endif %}

        {% if about_accent_title or about_accent_body %}
          <div class="about-card-accent">
            {% if about_accent_title %}
              <h4>{{ about_accent_title }}</h4>
            {% endif %}
            {% if about_accent_body %}
              <p>{{ about_accent_body }}</p>
            {% endif %}
          </div>
        {% endif %}
      </div>

      {# Columna derecha: descripción + features #}
      <div>
        <div class="reveal reveal-delay-1">
          {% if about_section_tag %}
            <p class="section-tag">{{ about_section_tag }}</p>
          {% endif %}
          {% if about_section_title %}
            <h2 class="section-title">{{ about_section_title }}</h2>
          {% endif %}
          {% if about_section_desc %}
            <p class="section-desc">{{ about_section_desc }}</p>
          {% endif %}
        </div>

        {% if about_features %}
          <div class="about-features reveal reveal-delay-2">
            {# Slot: .feature-item divs con icono, <strong> y <span> #}
            {{ about_features }}
          </div>
        {% endif %}
      </div>

    </div>
  </div>
</section>

{# ─────────────────────────────────────────────
   JOURNEY
───────────────────────────────────────────── #}
<section class="journey" id="journey">
  <div class="container">
    <div class="journey-header reveal">
      {% if journey_section_tag %}
        <p class="section-tag">{{ journey_section_tag }}</p>
      {% endif %}
      {% if journey_section_title %}
        <h2 class="section-title">{{ journey_section_title }}</h2>
      {% endif %}
      {% if journey_section_desc %}
        <p class="section-desc" style="margin: 0 auto;">{{ journey_section_desc }}</p>
      {% endif %}
    </div>

    <div class="journey-track">
      {# Slot: .sem-card y .journey-connector alternados (4 cards + 3 conectores) #}
      {{ journey_semesters }}
    </div>

    {% if journey_split_note %}
      <div style="text-align:center; margin-top:2.5rem;" class="reveal">
        <div class="journey-split-note" style="display:inline-block;">
          <p>{{ journey_split_note }}</p>
        </div>
      </div>
    {% endif %}
  </div>
</section>

{# ─────────────────────────────────────────────
   UNIVERSITIES
───────────────────────────────────────────── #}
<section class="universities" id="universities">
  <div class="container">
    <div class="reveal">
      {% if universities_section_tag %}
        <p class="section-tag">{{ universities_section_tag }}</p>
      {% endif %}
      {% if universities_section_title %}
        <h2 class="section-title">{{ universities_section_title }}</h2>
      {% endif %}
      {% if universities_section_desc %}
        <p class="section-desc">{{ universities_section_desc }}</p>
      {% endif %}
    </div>

    {% if universities %}
      <div class="uni-grid">
        {# Slot: .uni-card divs con país, nombre, abreviatura, descripción y tags #}
        {{ universities }}
      </div>
    {% endif %}
  </div>
</section>

{# ─────────────────────────────────────────────
   SPECIALIZATIONS
───────────────────────────────────────────── #}
<section class="specializations" id="specializations">
  <div class="container">
    <div class="spec-header">
      <div class="reveal">
        {% if spec_section_tag %}
          <p class="section-tag">{{ spec_section_tag }}</p>
        {% endif %}
        {% if spec_section_title %}
          <h2 class="section-title">{{ spec_section_title }}</h2>
        {% endif %}
      </div>
      {% if spec_section_desc %}
        <p class="section-desc reveal reveal-delay-1" style="max-width: 360px;">
          {{ spec_section_desc }}
        </p>
      {% endif %}
    </div>

    {% if specializations %}
      <div class="spec-grid">
        {# Slot: .spec-card divs con .spec-top y .spec-body #}
        {{ specializations }}
      </div>
    {% endif %}
  </div>
</section>

{# ─────────────────────────────────────────────
   WHY LSCM
───────────────────────────────────────────── #}
<section class="why">
  <div class="container">
    <div class="reveal">
      {% if why_section_tag %}
        <p class="section-tag">{{ why_section_tag }}</p>
      {% endif %}
      {% if why_section_title %}
        <h2 class="section-title" style="color:white;">{{ why_section_title }}</h2>
      {% endif %}
    </div>

    {% if why_items %}
      <div class="why-grid">
        {# Slot: .why-item divs con .why-num, h4 y p #}
        {{ why_items }}
      </div>
    {% endif %}
  </div>
</section>

{# ─────────────────────────────────────────────
   ADMISSION
───────────────────────────────────────────── #}
<section class="admission" id="admission">
  <div class="container">
    <div class="admission-grid">

      {# Columna izquierda: intro + timeline #}
      <div>
        <div class="reveal">
          {% if admission_section_tag %}
            <p class="section-tag">{{ admission_section_tag }}</p>
          {% endif %}
          {% if admission_section_title %}
            <h2 class="section-title">{{ admission_section_title }}</h2>
          {% endif %}
          {% if admission_section_desc %}
            <p class="section-desc">{{ admission_section_desc }}</p>
          {% endif %}
        </div>

        {% if timeline_items %}
          <div class="timeline reveal reveal-delay-1">
            {# Slot: .timeline-item divs con dot/line visual y .timeline-content #}
            {{ timeline_items }}
          </div>
        {% endif %}
      </div>

      {# Columna derecha: requisitos + CTA #}
      <div>
        {% if requirements_tag %}
          <p class="section-tag reveal">{{ requirements_tag }}</p>
        {% endif %}

        {% if requirements_cards %}
          <div class="req-cards reveal reveal-delay-1">
            {# Slot: .req-card divs con icono, título y descripción #}
            {{ requirements_cards }}
          </div>
        {% endif %}

        {% if req_cta_title or req_cta_url %}
          <div class="req-cta reveal reveal-delay-2">
            {% if req_cta_title %}
              <h4>{{ req_cta_title }}</h4>
            {% endif %}
            {% if req_cta_desc %}
              <p>{{ req_cta_desc }}</p>
            {% endif %}
            {% if req_cta_url and req_cta_button_text %}
              <a href="{{ req_cta_url }}" target="_blank">{{ req_cta_button_text }} &rarr;</a>
            {% endif %}
          </div>
        {% endif %}
      </div>

    </div>
  </div>
</section>

{# ─────────────────────────────────────────────
   CTA SECTION
───────────────────────────────────────────── #}
<section class="cta-section">
  <div class="container">
    <div class="cta-inner reveal">
      {% if cta_section_tag %}
        <p class="section-tag">{{ cta_section_tag }}</p>
      {% endif %}
      {% if cta_section_title %}
        <h2 class="section-title">{{ cta_section_title }}</h2>
      {% endif %}
      {% if cta_section_desc %}
        <p class="section-desc">{{ cta_section_desc }}</p>
      {% endif %}
      <div class="cta-btns">
        {% if cta_email %}
          <a href="mailto:{{ cta_email }}" class="btn-blue">📧 {{ cta_email }}</a>
        {% endif %}
        {% if cta_faq_url and cta_faq_text %}
          <a href="{{ cta_faq_url }}" target="_blank" class="btn-primary">{{ cta_faq_text }} &rarr;</a>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{# ─────────────────────────────────────────────
   FOOTER
───────────────────────────────────────────── #}
<footer>
  <div class="footer-inner">
    <div class="footer-top">

      <div class="footer-brand">
        <span class="nav-brand-top">{{ footer_brand_name }}</span>
        {% if footer_brand_desc %}
          <p>{{ footer_brand_desc }}</p>
        {% endif %}
      </div>

      {% if footer_col1_links %}
        <div class="footer-col">
          {% if footer_col1_title %}
            <h5>{{ footer_col1_title }}</h5>
          {% endif %}
          <ul>
            {# Slot: <li> elements con enlaces del bloque "Programme" #}
            {{ footer_col1_links }}
          </ul>
        </div>
      {% endif %}

      {% if footer_col2_links %}
        <div class="footer-col">
          {% if footer_col2_title %}
            <h5>{{ footer_col2_title }}</h5>
          {% endif %}
          <ul>
            {# Slot: <li> elements con enlaces del bloque "Admissions" #}
            {{ footer_col2_links }}
          </ul>
        </div>
      {% endif %}

      {% if footer_col3_links %}
        <div class="footer-col">
          {% if footer_col3_title %}
            <h5>{{ footer_col3_title }}</h5>
          {% endif %}
          <ul>
            {# Slot: <li> elements con enlaces del bloque "Partners" #}
            {{ footer_col3_links }}
          </ul>
        </div>
      {% endif %}

    </div>

    <div class="footer-bottom">
      {% if footer_copyright %}
        <p>{{ footer_copyright }}</p>
      {% endif %}
      {% if footer_eu_badge_text %}
        <div class="eu-badge">
          <span>🇪🇺</span>
          <span>{{ footer_eu_badge_text }}</span>
        </div>
      {% endif %}
    </div>
  </div>
</footer>

</body>
</html>
